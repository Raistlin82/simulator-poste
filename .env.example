# Environment Configuration Example
# Copy this file to .env and customize values

# Application Environment (development, staging, production)
ENVIRONMENT=development

# Frontend URL (for CORS configuration)
FRONTEND_URL=http://localhost:5173

# Backend Configuration
PORT=8000
DATABASE_URL=sqlite:///./simulator_poste.db

# --- Authentication (SAP IAS / OIDC) ---
# Provide these in staging/production. If OIDC_CLIENT_ID is empty the backend
# fails closed UNLESS AUTH_DEV_BYPASS=1 is set (local development only).
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_AUDIENCE=
# Local-only: run without authentication. NEVER enable in staging/production.
AUTH_DEV_BYPASS=1
# Comma-separated emails/subs allowed to use admin endpoints (DB import/export).
# Empty => admin endpoints are denied (fail closed) unless AUTH_DEV_BYPASS=1.
ADMIN_EMAILS=

# Logging Level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# AI Chat Provider (gemini | claude | groq) — configured via Master Data UI
# Google Gemini — free tier at aistudio.google.com
GOOGLE_API_KEY=your-google-api-key-here

# Groq — free tier at console.groq.com
GROQ_API_KEY=your-groq-api-key-here

# Anthropic Claude — pay-per-use at console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-...

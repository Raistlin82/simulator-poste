# Environment Configuration Example
# Copy this file to .env and customize values

# Application Environment (development, staging, production)
ENVIRONMENT=development

# Frontend URL (for CORS configuration)
FRONTEND_URL=http://localhost:5173

# Backend Configuration
PORT=8000
DATABASE_URL=sqlite:///./simulator_poste.db

# Logging Level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# AI Chat Provider (gemini | claude | groq) — configured via Master Data UI
# Google Gemini — free tier at aistudio.google.com
GOOGLE_API_KEY=your-google-api-key-here

# Groq — free tier at console.groq.com
GROQ_API_KEY=your-groq-api-key-here

# Anthropic Claude — pay-per-use at console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-...

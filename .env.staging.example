# Staging Environment Configuration

ENVIRONMENT=staging
FRONTEND_URL=https://staging.simulator-poste.example.com
PORT=8000
DATABASE_URL=sqlite:///./simulator_poste.db
LOG_LEVEL=DEBUG

# SAP IAS / OIDC - required outside local development
OIDC_ISSUER=https://your-ias.accounts.ondemand.com
OIDC_CLIENT_ID=your-client-id
OIDC_AUDIENCE=your-client-id
AUTH_DEV_BYPASS=0
ADMIN_EMAILS=admin@example.com

# AI providers used by OCR/chat features, enabled from Master Data UI
GOOGLE_API_KEY=
GROQ_API_KEY=
ANTHROPIC_API_KEY=
